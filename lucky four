import java.util.Scanner;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int T = sc.nextInt();

        while (T-- > 0) {
            int n = sc.nextInt();
            int count = 0;

            while (n > 0) {
                int digit = n % 10;

                if (digit == 4) {
                    count++;
                }

                n = n / 10;
            }

            System.out.println(count);
        }
    }
}
